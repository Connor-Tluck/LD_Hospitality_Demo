# Put real values in `.env` and/or `.env.local` in this folder (`mobile/`), then restart Expo.
# Expo loads both; `.env.local` overrides `.env` for the same keys (good for secrets — it’s gitignored).
# Run the app from this workspace (`npm run dev:mobile` from repo root, or `cd mobile && npx expo start`)
# so the CLI picks up these files. See https://docs.expo.dev/guides/environment-variables/

# LaunchDarkly mobile key (Project → Environments → Mobile key).
EXPO_PUBLIC_LAUNCHDARKLY_MOBILE_KEY=mob-your-key-here

# Demo flags (create as boolean flags in the same environment; keys must match code in `src/lib/ld/flags.ts`):
#   - demo-home-feature — Elevate Rewards promo on Home
#   - demo-bookings-calendar — “Trip calendar” entry on Bookings + `/bookings/calendar` observability demo (intentional error)
#
# Observability: `@launchdarkly/observability-react-native` is wired in `src/lib/ld/client.ts` (errors, logs, traces, metrics).
# In the LaunchDarkly UI, enable Observability for the project and review sessions/errors/metrics there. Mobile session replay
# is configured in your LD Observability / project settings (not via a separate env var in this app).

# Optional: comma-separated emails that receive the "beta" permission in LaunchDarkly user context (targeting).
# EXPO_PUBLIC_LD_BETA_EMAILS=you@company.com,beta.user@example.com

# Local demo auth (default): no network; any non-empty email/password signs you in on-device.
# LaunchDarkly identify() uses the email you enter + demo org (org-demo-1).
# Set to false or 0 to use the Node mock API instead (run `npm run dev:server` from repo root).
EXPO_PUBLIC_LOCAL_DEMO_AUTH=true

# Chat support (flag `chat-support`): the mock API needs `LAUNCHDARKLY_SDK_KEY` (server SDK key) + `OPENAI_API_KEY`.
# You can put them here in `mobile/.env.local` — the server loads this file too — or in `server/.env.local` (see
# `server/.env.example`). The mobile `EXPO_PUBLIC_LAUNCHDARKLY_MOBILE_KEY` is only for the app, not the API.

# Only when EXPO_PUBLIC_LOCAL_DEMO_AUTH is false: mock API URL.
# If unset, the app builds a URL from Expo’s dev host (works for many physical-device setups) or http://127.0.0.1:8787.
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8787

# Optional — LaunchDarkly CLI (`ldcli`): sourcemaps upload, flags, etc.
# Create an API access token: https://app.launchdarkly.com/settings/authorization (Writer or Admin for uploads).
# Run `bash scripts/ld-cli-config.sh` from the `mobile/` folder so the CLI uses THIS token + project (not an old global one).
# Source maps for error stack symbolication: `bash scripts/generate-ld-sourcemaps.sh`, then `ldcli sourcemaps upload --project ... --app-version ... --path .ld-sourcemaps`
# LD_API_KEY=api-your-token-here
# LD_PROJECT_KEY=<from `ldcli projects list` — must match the project key, not the display name>
# LD_ENVIRONMENT_KEY=production

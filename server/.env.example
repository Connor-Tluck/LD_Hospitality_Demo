# Copy to `.env` and/or `.env.local` in this folder (`server/`), or put the same keys in `mobile/.env.local` — the server
# loads both (with this file winning if both define the same variable). Restart `npm run dev:server` after changes.

# Required for chat welcome + AI turns — NOT the mobile key. Use: Project → Environments → SDK key (server-side).
LAUNCHDARKLY_SDK_KEY=sdk-your-server-key-here

# Required to send chat messages (OpenAI completions). The LaunchDarkly OpenAI provider reads this from the environment.
OPENAI_API_KEY=sk-your-openai-key-here

# AI Config key in LaunchDarkly (completion mode, provider OpenAI). Default in code is `hospitality-chat`.
# Variations (e.g. Booking Support vs Hostile Bot) are selected only by LaunchDarkly targeting for that key.
# LAUNCHDARKLY_AI_CONFIG_KEY=hospitality-chat

# PORT=8787
